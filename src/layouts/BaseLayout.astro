---
import Header from '../components/layout/Header.svelte';
import TopNav from '../components/layout/TopNav.svelte';
import MobileSidebar from '../components/layout/MobileSidebar.svelte';
import Sidebar from '../components/layout/Sidebar.svelte';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Simple Programming' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Learn programming through visual, interactive lessons"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Permanent+Marker&family=Roboto:wght@200;300;400;500;700&display=swap" rel="stylesheet" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="No jargon. No boring tutorials. Just colorful, interactive lessons that make programming click." />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Programming Is Easy" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="No jargon. No boring tutorials. Just colorful, interactive lessons that make programming click." />
    <meta name="twitter:image" content="/twitter-card.png" />

    <!-- Schema.org structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Programming Is Easy",
      "description": "No jargon. No boring tutorials. Just colorful, interactive lessons that make programming click.",
      "image": "/schema-image.png"
    })} />

    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <Header client:load />
    <TopNav client:load currentPath={Astro.url.pathname} />

    <div class="w-full flex-1 flex isolate" style="z-index: 1;">
      <main class="flex-1 min-w-0 px-3 pt-4 pb-4 md:px-6 md:pb-6 lg:px-12 lg:pb-8">
        <slot />
      </main>
    </div>

  </body>
</html>
