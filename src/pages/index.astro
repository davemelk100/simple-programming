---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressBar from '../components/ui/ProgressBar.svelte';
import ArchitectureDiagram from '../components/ui/ArchitectureDiagram.svelte';
---

<BaseLayout title="Programming Is Easy">
  <!-- Hero -->
  <section class="mb-3">
    <h1 class="text-center text-3xl font-black text-slate-800">Computer software is constructed like a <span class="text-amber-700">bank</span></h1>
    <p class="mt-2 text-center text-sm text-slate-500" style="font-family: 'Roboto', sans-serif;">It is how you access the vault that holds your cash.</p>
  </section>

  <!-- Architecture diagram -->
  <section class="mb-10">
    <ArchitectureDiagram client:visible />
  </section>

  <!-- Progress bar (filled by client-side JS if logged in) -->
  <div id="progress-section" class="mb-4 hidden">
    <ProgressBar client:load percentage={0} label="Overall Progress" />
  </div>
</BaseLayout>
