---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressBar from '../components/ui/ProgressBar.svelte';
import ArchitectureDiagram from '../components/ui/ArchitectureDiagram.svelte';
---

<BaseLayout title="Programming Is Easy">
  <!-- Hero -->
  <section class="mb-3">
    <h1 class="text-center text-3xl font-black text-slate-800">How Software Fits Together</h1>
    <p class="mt-2 text-center text-sm text-slate-500">Think of a tech stack like a <strong class="text-amber-700">bank</strong>, built from the foundation up to the moment cash hits your hand.</p>
  </section>

  <!-- Architecture diagram -->
  <section class="mb-10">
    <ArchitectureDiagram client:visible />
  </section>

  <!-- Progress bar (filled by client-side JS if logged in) -->
  <div id="progress-section" class="mb-4 hidden">
    <ProgressBar client:load percentage={0} label="Overall Progress" />
  </div>
</BaseLayout>
