---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicCard from '../components/ui/TopicCard.svelte';
import ProgressBar from '../components/ui/ProgressBar.svelte';
import ArchitectureDiagram from '../components/ui/ArchitectureDiagram.svelte';
import { topics } from '../lib/topics';
---

<BaseLayout title="Simple Programming - Learn the Visual Way">
  <!-- Hero -->
  <section class="mb-8 lg:mb-12">
    <h1 class="text-3xl font-black text-slate-800">
      Learn Programming <span class="bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">the Visual Way</span>
    </h1>
  </section>

  <!-- Architecture diagram -->
  <section class="mb-10">
    <ArchitectureDiagram client:visible />
  </section>

  <!-- Progress bar (filled by client-side JS if logged in) -->
  <div id="progress-section" class="mb-4 hidden">
    <ProgressBar client:load percentage={0} label="Overall Progress" />
  </div>

  <!-- Topic grid -->
  <section>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {topics.map((topic) => (
        <TopicCard client:load topic={topic} completed={false} />
      ))}
    </div>
  </section>
</BaseLayout>
