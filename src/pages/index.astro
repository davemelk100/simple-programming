---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressBar from '../components/ui/ProgressBar.svelte';
import ArchitectureDiagram from '../components/ui/ArchitectureDiagram.svelte';
---

<BaseLayout title="Programming Is Easy">
  <!-- Lead-in text -->
  <section class="flex flex-col items-start pb-6">
    <h1 class="text-xl sm:text-xl font-bold text-slate-800 mb-4" style="font-family: 'Permanent Marker', cursive;">Think of software like a bank.</h1>
    <p class="text-sm text-slate-600 leading-relaxed mb-3">
      Every app is built from the same handful of layers. This site maps each one to a part of a bank: the <strong class="text-slate-700">building</strong> (core concepts), <strong class="text-amber-700">rules &amp; policies</strong> (syntax &amp; principles), the <strong class="text-green-700">vault</strong> (languages &amp; tools), <strong class="text-purple-700">employees</strong> (building &amp; shipping), and the <strong class="text-blue-700">lobby</strong> (user interface).
    </p>
    <p class="text-sm text-slate-500 leading-relaxed pb-3">
      Walk through each layer below and you'll see: programming isn't magic, it's architecture.
    </p>
  </section>

  <!-- Architecture diagram -->
  <section class="-mt-6 mb-10 lg:-mt-8">
    <ArchitectureDiagram client:visible />
  </section>

  <!-- Progress bar (filled by client-side JS if logged in) -->
  <div id="progress-section" class="mb-4 hidden">
    <ProgressBar client:load percentage={0} label="Overall Progress" />
  </div>
</BaseLayout>
